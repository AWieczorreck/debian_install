+                    "[ -z \"$LINENUM\" ] && exit; "
+                    "LINENUM=$((LINENUM - 1)); "  /* eine Zeile weniger */
+                    "WID=$(cat /tmp/st-wid 2>/dev/null); "
+                    "[ -z \"$WID\" ] && exit; "
+                    "rm -f /tmp/st-fzf-done; "
+                    "xdotool click --window \"$WID\" --repeat \"$LINENUM\" --delay 0 4",
+                    NULL);
+                exit(0);
+        }
+}
