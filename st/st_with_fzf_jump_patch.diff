+void
+externalpipe(const Arg *arg)
+{
+	int to[2];
+	char buf[UTF_SIZ];
+	void (*oldsigpipe)(int);
+	Glyph *bp, *end;
+	int lastpos, n, newline;
+
+	if (pipe(to) == -1)
+		return;
+
+	switch (fork()) {
+	case -1:
+		close(to[0]);
+		close(to[1]);
+		return;
+	case 0:
+		dup2(to[0], STDIN_FILENO);
+		close(to[0]);
+		close(to[1]);
+		execvp(((char **)arg->v)[0], (char **)arg->v);
+		fprintf(stderr, "st: execvp %s\n", ((char **)arg->v)[0]);
+		perror("failed");
+		exit(0);
+	}
+
+	close(to[0]);
+	/* ignore sigpipe for now, in case child exists early */
+	oldsigpipe = signal(SIGPIPE, SIG_IGN);
+
+newline = 0;
+        for (n = -(HISTSIZE - term.row - 1); n < term.row; n++) {
+                bp = TLINE(n);
+                lastpos = MIN(tlinehistlen2(n) + 1, term.col) - 1;
+                if (lastpos < 0)
+                        lastpos = 0;
+                end = &bp[lastpos + 1];
+                for (; bp < end; ++bp)
+                        if (xwrite(to[1], buf, utf8encode(bp->u, buf)) < 0)
+                                break;
+                if ((newline = TLINE(n)[lastpos].mode & ATTR_WRAP))
+                        continue;
+                if (xwrite(to[1], "\n", 1) < 0)
+                        break;
+                newline = 0;
+        }
+
+	if (newline)
+		(void)xwrite(to[1], "\n", 1);
+	close(to[1]);
+	/* restore */
+	signal(SIGPIPE, oldsigpipe);
+}
+
+void
+externalpipe_jump(const Arg *arg)
+{
+        int to[2];
+        char buf[UTF_SIZ];
+        void (*oldsigpipe)(int);
+        Glyph *bp, *end;
+        int lastpos, n, newline;
+        pid_t pid;
+
+        if (pipe(to) == -1)
+                return;
+
+        switch ((pid = fork())) {
+        case -1:
+                close(to[0]);
+                close(to[1]);
+                return;
+        case 0:
+                /* Child: fzf ausführen */
+                dup2(to[0], STDIN_FILENO);
+                close(to[0]);
+                close(to[1]);
+                execvp(((char **)arg->v)[0], (char **)arg->v);
+                fprintf(stderr, "st: execvp %s\n", ((char **)arg->v)[0]);
+                perror("failed");
+                exit(0);
+        }
+        close(to[0]);
+        oldsigpipe = signal(SIGPIPE, SIG_IGN);
